{% extends "layout.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a class="govuk-back-link" href="/tasks">Back</a>

      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

      {% set titleError = "" %}
      {% set descriptionError = "" %}
      {% set statusError = "" %}
      {% set dueDateTimeError = "" %}

      {% if errors and errors.length %}
        {% for e in errors %}
          {% if e.field == "title" %}{% set titleError = e.message %}{% endif %}
          {% if e.field == "description" %}{% set descriptionError = e.message %}{% endif %}
          {% if e.field == "status" %}{% set statusError = e.message %}{% endif %}
          {% if e.field == "dueDateTime" %}{% set dueDateTimeError = e.message %}{% endif %}
        {% endfor %}

        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                {% for e in errors %}
                  <li><a href="#{{ e.field }}">{{ e.message }}</a></li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <form method="post" action="{{ formAction }}">

        <div class="govuk-form-group {% if titleError %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="title">Title</label>
          {% if titleError %}
            <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ titleError }}</p>
          {% endif %}
          <input class="govuk-input {% if titleError %}govuk-input--error{% endif %}"
                 id="title" name="title" type="text"
                 value="{{ values.title | default('') }}">
        </div>

        <div class="govuk-form-group {% if descriptionError %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="description">Description (optional)</label>
          {% if descriptionError %}
            <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ descriptionError }}</p>
          {% endif %}
          <textarea class="govuk-textarea {% if descriptionError %}govuk-textarea--error{% endif %}"
                    id="description" name="description" rows="5">{{ values.description | default('') }}</textarea>
        </div>

        <div class="govuk-form-group {% if statusError %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="status">Status</label>
          {% if statusError %}
            <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ statusError }}</p>
          {% endif %}
          {% set current = values.status | default('TODO') %}
          <select class="govuk-select {% if statusError %}govuk-select--error{% endif %}" id="status" name="status">
            <option value="TODO" {{ 'selected' if current == 'TODO' }}>To do</option>
            <option value="IN_PROGRESS" {{ 'selected' if current == 'IN_PROGRESS' }}>In progress</option>
            <option value="DONE" {{ 'selected' if current == 'DONE' }}>Done</option>
          </select>
        </div>

        <div class="govuk-form-group {% if dueDateTimeError %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="dueDateTime">Due date/time</label>
          {% if dueDateTimeError %}
            <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ dueDateTimeError }}</p>
          {% endif %}
          <input class="govuk-input {% if dueDateTimeError %}govuk-input--error{% endif %}"
                 id="dueDateTime" name="dueDateTime" type="datetime-local"
                 value="{{ values.dueDateTime | default('') }}">
        </div>

        <button class="govuk-button" type="submit">Save</button>
        <a class="govuk-link" href="/tasks">Cancel</a>
      </form>

    </div>
  </div>
{% endblock %}
