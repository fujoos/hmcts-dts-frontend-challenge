{% extends "layout.njk" %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a class="govuk-back-link" href="/tasks">Back</a>

      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

      {% set fieldErrors = {} %}
      {% if errors and errors.length %}
        {% for e in errors %}
          {% set fieldErrors = fieldErrors | merge({ (e.field): e.message }) %}
        {% endfor %}

        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                {% for e in errors %}
                  <li><a href="#{{ e.field }}">{{ e.message }}</a></li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <form method="post" action="{{ formAction }}">

        <div class="govuk-form-group {% if fieldErrors.title %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="title">Title</label>
          {% if fieldErrors.title %}
            <p class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ fieldErrors.title }}
            </p>
          {% endif %}
          <input class="govuk-input {% if fieldErrors.title %}govuk-input--error{% endif %}"
                 id="title" name="title" type="text"
                 value="{{ values.title | default('') }}">
        </div>

        <div class="govuk-form-group {% if fieldErrors.description %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="description">Description (optional)</label>
          {% if fieldErrors.description %}
            <p class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ fieldErrors.description }}
            </p>
          {% endif %}
          <textarea class="govuk-textarea {% if fieldErrors.description %}govuk-textarea--error{% endif %}"
                    id="description" name="description" rows="5">{{ values.description | default('') }}</textarea>
        </div>

        <div class="govuk-form-group {% if fieldErrors.status %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="status">Status</label>
          {% if fieldErrors.status %}
            <p class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ fieldErrors.status }}
            </p>
          {% endif %}
          {% set current = values.status | default('TODO') %}
          <select class="govuk-select {% if fieldErrors.status %}govuk-select--error{% endif %}" id="status" name="status">
            <option value="TODO" {{ 'selected' if current == 'TODO' }}>To do</option>
            <option value="IN_PROGRESS" {{ 'selected' if current == 'IN_PROGRESS' }}>In progress</option>
            <option value="DONE" {{ 'selected' if current == 'DONE' }}>Done</option>
          </select>
        </div>

        <div class="govuk-form-group {% if fieldErrors.dueDateTime %}govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="dueDateTime">Due date/time</label>
          {% if fieldErrors.dueDateTime %}
            <p class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ fieldErrors.dueDateTime }}
            </p>
          {% endif %}
          <input class="govuk-input {% if fieldErrors.dueDateTime %}govuk-input--error{% endif %}"
                 id="dueDateTime" name="dueDateTime" type="datetime-local"
                 value="{{ values.dueDateTime | default('') }}">
        </div>

        <button class="govuk-button" type="submit">Save</button>
        <a class="govuk-link" href="/tasks">Cancel</a>
      </form>

    </div>
  </div>
{% endblock %}
